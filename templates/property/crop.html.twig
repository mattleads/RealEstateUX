{% extends 'base.html.twig' %}

{% block title %}Crop Photo{% endblock %}

{% block body %}
    <div class="max-w-3xl mx-auto bg-white p-8 rounded-xl shadow-lg">
        <h1 class="text-4xl font-bold mb-8 text-gray-900">
            Crop Cover Photo
        </h1>
        <p class="mb-4 text-gray-600">Drag to position the image and use the corners to resize the crop area.</p>

        {{ form_start(form) }}
            <div class="mb-6">
                {{ form_widget(form.photo) }}
            </div>

            <div class="flex items-center space-x-4">
                <button type="submit" class="flex-1 flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Save Crop
                </button>
                
                <a href="{{ path('app_property_index') }}" class="flex-1 flex justify-center py-3 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Skip
                </a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
